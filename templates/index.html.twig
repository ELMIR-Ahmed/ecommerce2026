{% extends 'layout/layout.html.twig' %}

{% block content %}
    <div class="container my-5">
        <h1 class="mb-4">Our Products</h1>

        <div class="row row-cols-1 row-cols-md-3 g-4">

            {# On boucle sur la variable 'products' envoyée par le contrôleur #}
            {% for product in products %}
                <div class="col">
                    <div class="card h-100">
                        <img src="item.png" class="card-img-top" alt="{{ product.name }}">
                        <div class="card-body">
                            {# Exemple de propriété dynamique #}
                            <span class="badge bg-primary mb-2">{{ product.category.name }}</span>
                            <h5 class="card-title">{{ product.name }}</h5>
                            <p class="card-text fw-bold text-success">{{ product.price }} €</p>

                            {# Génération du lien vers la page détail avec l'ID du produit #}
                            <a href="{{ path('app_product_show', {id: product.id}) }}" class="btn btn-outline-primary">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            {% else %}
                <p>Aucun produit disponible pour le moment.</p>
            {% endfor %}

        </div>
    </div>
{% endblock content %}
